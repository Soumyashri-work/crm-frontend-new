# .env.example — copy to `.env` and fill values
# Do not commit secrets. This file shows client-visible variables only.

# Base API URL used by the frontend for all API requests  (the backend server URL)
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Keycloak configuration
VITE_KEYCLOAK_URL=https://auth.example.com/auth
VITE_KEYCLOAK_REALM=unified-crm
VITE_KEYCLOAK_CLIENT=crm-frontend

# Optional legacy env var (not used by Vite but present for reference)
# REACT_APP_API_BASE_URL=http://localhost:8000/api/v1

# Notes:
# - Replace example values with real endpoints for your environment.
# - Keep this file local. Use a secrets manager or CI/CD env settings for production.
# - For local development, you can run Keycloak locally or point to a shared dev Keycloak.